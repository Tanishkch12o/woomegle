rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Prevent default public access
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure user profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // Secure chat rooms (only participants can read/update)
    match /rooms/{roomId} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
    }

    // Secure subscriptions
    match /subscriptions/{subId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.user || request.auth.token.isAdmin == true);
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // Secure bans & moderation data
    match /bans/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // Secure invoices
    match /invoices/{invId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.isAdmin == true);
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // Secure analytics data
    match /analytics/{docId} {
      allow read: if request.auth != null && request.auth.token.isAdmin == true;
      allow write: if false; // Only backend admin SDK can write analytics
    }
  }
}
